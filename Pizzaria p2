 <form id="form-pedido" action="#" method="post">
  <div class="formulario"> 
    Nome: <input type="text" id="nome" name="nome" placeholder="Digite seu nome" maxlength="30" required>
    <br><br>
    Endereço: <input type="text" id="endereco" name="endereco" placeholder="Digite seu endereço" maxlength="90" required>
  </div>
  <br><br>
  <button type="submit" class="btn btn-danger"> <i class="fa fa-arrow-right"></i> Enviar</button>
  <button type="reset" class="btn btn-danger"><i class="fa fa-arrow-right"></i> Limpar</button>
</form>

<script>
  document.getElementById('form-pedido').addEventListener('submit', function(e) {
    e.preventDefault(); // impede o envio tradicional

    // Coleta nome e endereço
    const nome = document.getElementById('nome').value.trim();
    const endereco = document.getElementById('endereco').value.trim();

    if (nome === '' || endereco === '') {
      alert('Por favor, preencha nome e endereço.');
      return;
    }

    // Coleta os itens selecionados e o total do resumo
    const listaItens = document.getElementById('lista-itens-resumo');
    const itensSelecionados = [];
    for (let li of listaItens.querySelectorAll('li')) {
      if (li.innerText !== 'Nenhum item selecionado') {
        itensSelecionados.push(li.innerText);
      }
    }

    const totalTexto = document.getElementById('total-resumo').innerText;
    const total = totalTexto.replace(',', '.'); // formata para exibição

    if (itensSelecionados.length === 0) {
      alert('Selecione pelo menos um item para fazer o pedido.');
      return;
    }

    // Monta a mensagem
    let mensagem = `*NOVO PEDIDO PIZZARIA*%0A`; // %0A = quebra de linha no WhatsApp
    mensagem += `*Nome:* ${nome}%0A`;
    mensagem += `*Endereço:* ${endereco}%0A`;
    mensagem += `*Itens:*%0A`;
    itensSelecionados.forEach(item => {
      mensagem += `- ${item}%0A`;
    });
    mensagem += `*Total:* R$ ${total}%0A`;
    mensagem += `%0A_Obrigado! Aguardamos a confirmação._`;

    // Substitua o número abaixo pelo seu número de WhatsApp (com código do país e DDD, sem espaços)
    const numeroWhatsApp = '5514997297669'; // EXEMPLO: 55 11 99999-9999 -> escrever 5511999999999
    const url = `https://wa.me/${numeroWhatsApp}?text=${mensagem}`;

    // Abre o WhatsApp em nova guia
    window.open(url, '_blank');
  });
</script>
