<div class="resumo-pedido">
  <h3>Seu pedido:</h3>
  <ul id="lista-itens-resumo">
    <li>Nenhum item selecionado</li>
  </ul>
  <script>
  function atualizarResumo() {
    // Seleciona todos os checkboxes de pedido
    const checkboxes = document.querySelectorAll('input[name="pedido[]"]');
    let itensSelecionados = [];
    let total = 0;

    checkboxes.forEach(checkbox => {
      if (checkbox.checked) {
        const textoCompleto = checkbox.value;
        // Extrai o preço do final do texto (ex: "Frango c/ bacon R$26,90")
        const match = textoCompleto.match(/R\$([0-9,]+)$/);
        if (match) {
          let preco = parseFloat(match[1].replace(',', '.'));
          total += preco;
        }
        // Remove o preço do texto para mostrar só a descrição
        const nomeItem = textoCompleto.replace(/ R\$[0-9,]+$/, '');
        itensSelecionados.push(nomeItem);
      }
    });

    // Atualiza a lista no resumo
    const listaUl = document.getElementById('lista-itens-resumo');
    const totalSpan = document.getElementById('total-resumo');

    if (itensSelecionados.length === 0) {
      listaUl.innerHTML = '<li>Nenhum item selecionado</li>';
    } else {
      listaUl.innerHTML = itensSelecionados.map(item => `<li>${item}</li>`).join('');
    }

    totalSpan.innerText = total.toFixed(2).replace('.', ',');
  }

  // Adiciona evento de 'change' a todos os checkboxes
  document.querySelectorAll('input[name="pedido[]"]').forEach(checkbox => {
    checkbox.addEventListener('change', atualizarResumo);
  });

  // Executa uma vez ao carregar a página para mostrar itens que já venham marcados (checked)
  window.addEventListener('DOMContentLoaded', atualizarResumo);
</script>

  <p><strong>Total: R$ <span id="total-resumo">0.00</span></strong></p>
