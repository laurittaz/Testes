.banner {
    background-image: url("img/imgp4.jpg");
    background-size: cover;
    background-position: center;
    height: 200px;
    width: 100%;
    position: relative;      /* Necessário para o before */
    display: flex;
    align-items: center;
    justify-content: center;
}

/* Camada preta transparente SOMENTE dentro do banner */
.banner::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 0.5); /* Preto 50% transparente */
    z-index: 1;
}

/* Título fica por cima da camada escura */
.banner h1 {
    font-family:Verdana;
    text-align: center;
    color: white;
    font-size: 90px;
    background-color: transparent; 
    padding: 20px 30px;
    margin: 0;
    position: relative;
    z-index: 2;
}
