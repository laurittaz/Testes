    border: 1px solid #ccc;
  }
  .resumo-pedido {
    background-color: #dc3444;       /* fundo claro, combinando com o tom de pizza */
    border-left: 8px solid #e75a68;  /* mesma cor dos botões (vermelho) */
    border-radius: 12px;
    padding: 20px 25px;
    margin: 30px 20px;
    font-family: Arial, sans-serif;
    box-shadow: 0 4px 8px rgba(0,0,0,0.05);
}

.resumo-pedido h3 {
    font-size: 28px;
    color:white;
    margin: 0 0 15px 0;
    font-family: Arial, sans-serif;
    display: flex;
    align-items: center;
    gap: 10px;
}

/* Lista de itens no resumo */
#lista-itens-resumo {
    list-style: none;
    padding: 0;
    margin: 0 0 15px 0;
}

#lista-itens-resumo li {
    background-color: #f8f9fa;
    padding: 8px 12px;
    margin-bottom: 6px;
    border-radius: 8px;
    font-size: 18px;
    font-family: Arial, sans-serif;
    border-left: 4px solid #dc3444;
}

/* Mensagem quando não há itens */
#lista-itens-resumo li:first-child:only-child {
    background-color: white;
    color: #6c757d;
    border-left-color: #6c757d;
    font-style: italic;
}

/* Total do pedido */
.resumo-pedido p {
    font-size: 24px;
    font-weight: bold;
    margin: 15px 0 0 0;
    padding-top: 10px;
    border-top: 2px dashed #dc3444;
    text-align: right;
    color: #333;
}

#total-resumo {
    color: #dc3444;
    font-size: 28px;
    background-color: #ffe6e8;
    padding: 4px 12px;
    border-radius: 30px;
    display: inline-block;
}
